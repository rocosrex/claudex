{
  "name": "claudex",
  "version": "1.10.3",
  "description": "Claudex - Claude Code 프로젝트 관리 허브. 할 일, 아이디어, 칸반보드, 터미널 통합",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electronmon .",
    "rebuild": "electron-rebuild",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "publish": "GH_TOKEN=$(gh auth token) electron-builder --mac --publish always"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "chokidar": "^5.0.0",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.0.0",
    "sherpa-onnx-node": "^1.12.28",
    "ssh2": "^1.17.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-rebuild": "^3.2.9",
    "electronmon": "^2.0.4"
  },
  "build": {
    "appId": "com.rocos.claudex",
    "productName": "Claudex",
    "publish": {
      "provider": "github",
      "owner": "rocosrex",
      "repo": "claudex",
      "releaseType": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "assets/**/*",
      "models/**/*"
    ]
  }
}
